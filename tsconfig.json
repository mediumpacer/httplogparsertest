{
  "compilerOptions": {
      "target": "esnext",
      "module": "NodeNext",
      "outDir": "dist",
      "rootDir": "src",
      "strict": true,
      "esModuleInterop": true,
      "moduleResolution": "nodenext"
  },
  "include": [
    "src"
  ],
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true,
    "esm": true,
    "allowImportingTsExtensions": true
  },
}